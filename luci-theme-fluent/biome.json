{
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*",
      "!src/scss/**/*",
      "!package/luci-theme-fluent/htdocs/luci-static/resources/view/fluent-config.js",
      "!package/luci-theme-fluent/htdocs/luci-static/resources/menu-fluent.js",
      "!package/luci-theme-fluent/htdocs/luci-static/fluent/css/fluent.css"
    ]
  },
  "vcs": {
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 200,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "css": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 200
    },
    "linter": {
      "enabled": true
    }
  },
  "javascript": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 200,
      "quoteStyle": "double"
    }
  }
}
