    "interfaces": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/interface"
          }
        },
        "monotonic_ms": {
          "type": "integer",
          "minimum": 0
        },
        "note": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        }
      },
      "required": [
        "interfaces"
      ]
    },
    "sysdevice": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "selected": {
          "type": "boolean"
        },
        "observed": {
          "type": "boolean"
        },
        "recommended_lan": {
          "type": "boolean"
        },
        "collect_allowed": {
          "type": "boolean"
        },
        "collect_reason": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        },
        "is_bridge": {
          "type": "boolean"
        },
        "is_bridge_port": {
          "type": "boolean"
        },
        "is_nss_ifb": {
          "type": "boolean"
        },
        "speed_mbps": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "name",
        "selected",
        "observed",
        "recommended_lan",
        "collect_allowed",
        "collect_reason",
        "is_bridge",
        "is_bridge_port",
        "is_nss_ifb"
      ]
    },
    "sysdevices": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "type": "integer",
          "const": 1
        },
        "devices": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sysdevice"
          }
        },
        "current_ifnames": {
          "type": "array",
          "description": "Interfaces currently active in the runtime collection attach set after validation and policy filtering.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "current_observed": {
          "type": "array",
          "description": "Interfaces currently active in the runtime observe-only set after validation and policy filtering.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "current_excluded": {
          "type": "array",
          "description": "Exclusions currently enforced by the runtime. Empty while interface_exclude remains compatibility-only.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "configured_ifnames": {
          "type": "array",
          "description": "Safe, de-duplicated UCI ifname and interface_include values before runtime eligibility filtering.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "configured_observed": {
          "type": "array",
          "description": "Safe, de-duplicated UCI observe values before runtime policy filtering.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "configured_excluded": {
          "type": "array",
          "description": "Safe, de-duplicated UCI interface_exclude values retained for compatibility.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "orphaned": {
          "type": "array",
          "description": "Configured interface names that are absent from the current sysdevice discovery result.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_configured": {
              "type": "integer",
              "minimum": 1
            },
            "max_name_length": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": ["max_configured", "max_name_length"]
        }
      },
      "required": [
        "contract_version",
        "devices",
        "current_ifnames",
        "current_observed",
        "current_excluded",
        "configured_ifnames",
        "configured_observed",
        "configured_excluded",
        "orphaned",
        "limits"
      ]
    }
  }
}
