{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lanspeed.local/schema.json",
  "title": "lanspeed ubus contract",
  "description": "Stable JSON contract for deterministic lanspeedd ubus method responses. Task 2 fixtures are skeleton values only and do not represent live traffic metrics.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/status"
    },
    {
      "$ref": "#/$defs/clients"
    },
    {
      "$ref": "#/$defs/overview"
    },
    {
      "$ref": "#/$defs/health"
    },
    {
      "$ref": "#/$defs/reload"
    },
    {
      "$ref": "#/$defs/interfaces"
    },
    {
      "$ref": "#/$defs/sysdevices"
    },
    {
      "$ref": "#/$defs/diagnostics"
    },
    {
      "$ref": "#/$defs/client_connections"
    }
  ],
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "unsupported"
      ]
    },
    "warning": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "description": "Machine-readable facts used to explain mode, confidence, conflicts, and warnings. Values may be strings, numbers, booleans, arrays, objects, or null."
    },
    "probeFailure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["command", "file", "uci", "ubus", "nss", "probe"]
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^(command|file|uci|ubus|nss|probe):[A-Za-z0-9_./<>-]+$"
        },
        "reason": {
          "type": "string",
          "enum": [
            "availability_failed",
            "execution_failed",
            "nonzero_exit",
            "timeout",
            "output_truncated",
            "read_failed",
            "load_failed",
            "query_failed",
            "state_probe_failed",
            "state_unreadable",
            "failed"
          ]
        },
        "exit_code": {
          "type": "integer"
        }
      },
      "required": ["kind", "source", "reason"]
    },
    "probeFailures": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "items": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/probeFailure"
          }
        },
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        }
      },
      "required": ["items", "total", "truncated"]
    },
    "healthEvidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "probe_failures": {
          "$ref": "#/$defs/probeFailures"
        }
      },
      "required": ["probe_failures"]
    },
    "collectorMode": {
      "type": "string",
      "enum": ["auto", "bpf", "nss_ecm_direct", "nss_conntrack_sync", "conntrack_netlink", "conntrack_procfs"]
    },
    "rateCollectorMode": {
      "type": "string",
      "enum": ["auto", "bpf", "nss_ecm_direct", "nss_conntrack_sync"]
    },
    "connCollectorMode": {
      "type": "string",
      "enum": ["auto", "conntrack_netlink", "conntrack_procfs"]
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bpf": {
          "type": "boolean"
        },
        "bpf_supported": {
          "type": "boolean"
        },
        "bpf_package": {
          "type": "boolean"
        },
        "bpf_object": {
          "type": "boolean"
        },
        "bpf_runtime_metrics": {
          "type": "boolean"
        },
        "conntrack_fallback": {
          "type": "boolean"
        },
        "live_metrics": {
          "type": "boolean"
        },
        "fw4": {
          "type": "boolean"
        },
        "nft": {
          "type": "boolean"
        },
        "software_flow_offload": {
          "type": "boolean"
        },
        "hardware_flow_offload": {
          "type": "boolean"
        },
        "nss": {
          "type": "boolean"
        },
        "nss_ecm_offload": {
          "type": "boolean"
        },
        "nss_ppe_offload": {
          "type": "boolean"
        },
        "nss_ecm_direct": {
          "type": "boolean"
        },
        "nss_bridge_mgr": {
          "type": "boolean"
        },
        "nss_ifb": {
          "type": "boolean"
        },
        "nss_nsm": {
          "type": "boolean"
        },
        "nss_dp": {
          "type": "boolean"
        },
        "nss_mcs": {
          "type": "boolean"
        },
        "fullcone": {
          "type": "boolean"
        },
        "nf_conntrack_acct": {
          "type": "boolean"
        },
        "flowtable_counter": {
          "type": "boolean"
        },
        "tc": {
          "type": "boolean"
        },
        "tc_clsact": {
          "type": "boolean"
        },
        "existing_tc_filters": {
          "type": "boolean"
        },
        "ifb": {
          "type": "boolean"
        },
        "sqm": {
          "type": "boolean"
        },
        "qosify": {
          "type": "boolean"
        },
        "openclash": {
          "type": "boolean"
        },
        "openclash_fake_ip": {
          "type": "boolean"
        },
        "openclash_tun_mix": {
          "type": "boolean"
        },
        "openclash_redirect_dns": {
          "type": "boolean"
        },
        "openclash_dns_chain_complete": {
          "type": "boolean"
        },
        "openclash_router_self_proxy": {
          "type": "boolean"
        },
        "openclash_udp_proxy": {
          "type": "boolean"
        },
        "openclash_ipv6": {
          "type": "boolean"
        },
        "dae": {
          "type": "boolean"
        },
        "homeproxy": {
          "type": "boolean"
        },
        "lan_bridge": {
          "type": "boolean"
        },
        "vlan": {
          "type": "boolean"
        },
        "wlan": {
          "type": "boolean"
        },
        "lan_edge": {
          "type": "boolean"
        },
        "safe_attach": {
          "type": "boolean"
        },
        "map_full": {
          "type": "boolean"
        }
      },
      "required": [
        "bpf",
        "bpf_supported",
        "bpf_package",
        "bpf_object",
        "bpf_runtime_metrics",
        "conntrack_fallback",
        "live_metrics",
        "fw4",
        "nft",
        "software_flow_offload",
        "hardware_flow_offload",
        "nss",
        "nss_ecm_offload",
        "nss_ppe_offload",
        "nss_ecm_direct",
        "nss_bridge_mgr",
        "nss_ifb",
        "nss_nsm",
        "nss_dp",
        "nss_mcs",
        "fullcone",
        "nf_conntrack_acct",
        "flowtable_counter",
        "tc",
        "tc_clsact",
        "existing_tc_filters",
        "ifb",
        "sqm",
        "qosify",
        "openclash",
        "openclash_fake_ip",
        "openclash_tun_mix",
        "openclash_redirect_dns",
        "openclash_dns_chain_complete",
        "openclash_router_self_proxy",
        "openclash_udp_proxy",
        "openclash_ipv6",
        "dae",
        "homeproxy",
        "lan_bridge",
        "vlan",
        "wlan",
        "lan_edge",
        "safe_attach",
        "map_full"
      ]
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "description": "Sliding-window coverage computed by the daemon from monotonic interface counters and integrated per-client rates. Direction semantics: tx = client upload (client→router), rx = client download (router→client).",
      "properties": {
        "quality": {
          "type": "string",
          "enum": ["warmup", "idle", "low_traffic", "counter_reset", "ok", "unsupported"]
        },
        "samples": {
          "type": "integer",
          "minimum": 0
        },
        "window_ms": {
          "type": "integer",
          "minimum": 0
        },
        "tx_pct": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "rx_pct": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "denom_rx_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "denom_tx_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "numer_rx_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "numer_tx_bytes": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["quality", "samples"]
    },
    "diagnosticHealthState": {
      "type": "string",
      "enum": [
        "healthy",
        "degraded",
        "unavailable",
        "disabled"
      ]
    },
    "diagnosticPublicError": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        },
        "category": {
          "type": "string",
          "enum": [
            "transport",
            "collection",
            "reload",
            "serialization",
            "platform"
          ]
        },
        "stage": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        },
        "retriable": {
          "type": "boolean"
        },
        "message_public": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        }
      },
      "required": [
        "code",
        "category",
        "stage",
        "retriable",
        "message_public"
      ]
    },
    "diagnosticCollection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "fresh",
            "stale",
            "degraded",
            "unavailable"
          ]
        },
        "generation": {
          "type": "integer",
          "minimum": 0
        },
        "last_attempt_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "last_success_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "age_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "refresh_interval_ms": {
          "type": "integer",
          "minimum": 500
        },
        "consecutive_failures": {
          "type": "integer",
          "minimum": 0
        },
        "retained": {
          "type": "boolean"
        },
        "last_error": {
          "anyOf": [
            {
              "$ref": "#/$defs/diagnosticPublicError"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "state",
        "generation",
        "last_attempt_ms",
        "last_success_ms",
        "age_ms",
        "refresh_interval_ms",
        "consecutive_failures",
        "retained",
        "last_error"
      ]
    },
    "diagnosticAlert": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "critical"
          ]
        },
        "component": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        },
        "state": {
          "type": "string",
          "const": "active"
        },
        "message_public": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        }
      },
      "required": [
        "id",
        "severity",
        "component",
        "state",
        "message_public"
      ]
    },
    "diagnosticConfigIssue": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "critical"
          ]
        },
        "option": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        },
        "state": {
          "type": "string",
          "enum": [
            "adjusted",
            "compatibility_only"
          ]
        },
        "message_public": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        }
      },
      "required": [
        "id",
        "severity",
        "option",
        "state",
        "message_public"
      ]
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "type": "integer",
          "const": 1
        },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "state": {
              "type": "string",
              "enum": [
                "starting",
                "running",
                "degraded"
              ]
            },
            "ubus_connected": {
              "type": "boolean"
            }
          },
          "required": [
            "state",
            "ubus_connected"
          ]
        },
        "collection": {
          "$ref": "#/$defs/diagnosticCollection"
        },
        "data_path": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "configured_rate": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "effective_rate": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]{1,64}$"
            },
            "configured_connection": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "effective_connection": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]{1,64}$"
            },
            "fallback_active": {
              "type": "boolean"
            },
            "reason_code": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[A-Za-z0-9_-]{1,64}$"
            }
          },
          "required": [
            "configured_rate",
            "effective_rate",
            "configured_connection",
            "effective_connection",
            "fallback_active",
            "reason_code"
          ]
        },
        "interfaces": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "state": {
              "$ref": "#/$defs/diagnosticHealthState"
            },
            "total": {
              "type": "integer",
              "minimum": 0
            },
            "available": {
              "type": "integer",
              "minimum": 0
            },
            "missing": {
              "type": "integer",
              "minimum": 0
            },
            "sample_ms": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            }
          },
          "required": [
            "state",
            "total",
            "available",
            "missing",
            "sample_ms"
          ]
        },
        "connection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "state": {
              "$ref": "#/$defs/diagnosticHealthState"
            },
            "source": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[A-Za-z0-9_-]{1,64}$"
            },
            "entries_seen": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "entries_matched": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "parse_errors": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            }
          },
          "required": [
            "state",
            "source",
            "entries_seen",
            "entries_matched",
            "parse_errors"
          ]
        },
        "subsystems": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]{1,64}$"
              },
              "state": {
                "$ref": "#/$defs/diagnosticHealthState"
              },
              "code": {
                "type": [
                  "string",
                  "null"
                ],
                "pattern": "^[A-Za-z0-9_-]{1,64}$"
              }
            },
            "required": [
              "id",
              "state",
              "code"
            ]
          }
        },
        "versions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "daemon": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "package": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "contract_version": {
              "type": "integer",
              "const": 1
            },
            "schema_version": {
              "type": "integer",
              "const": 1
            }
          },
          "required": [
            "daemon",
            "package",
            "contract_version",
            "schema_version"
          ]
        },
        "alerts": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/diagnosticAlert"
          }
        },
        "config_issues": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/diagnosticConfigIssue"
          }
        }
      },
      "required": [
        "contract_version",
        "service",
        "collection",
        "data_path",
        "interfaces",
        "connection",
        "subsystems",
        "versions",
        "alerts",
        "config_issues"
      ]
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "Full",
            "Degraded",
            "Unsupported"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        },
        "evidence": {
          "$ref": "#/$defs/healthEvidence"
        },
        "refresh_interval_ms": {
          "type": "integer",
          "minimum": 500
        },
        "active_client_window_ms": {
          "type": "integer",
          "minimum": 1000
        },
        "active_client_min_bps": {
          "type": "integer",
          "minimum": 1
        },
        "overview_window_samples": {
          "type": "integer",
          "minimum": 2
        },
        "collector_mode": {
          "$ref": "#/$defs/collectorMode"
        },
        "rate_collector_mode": {
          "$ref": "#/$defs/rateCollectorMode"
        },
        "conn_collector_mode": {
          "$ref": "#/$defs/connCollectorMode"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "capabilities": {
          "$ref": "#/$defs/capabilities"
        },
        "coverage": {
          "$ref": "#/$defs/coverage"
        }
      },
      "required": [
        "mode",
        "confidence",
        "warnings",
        "evidence",
        "refresh_interval_ms",
        "rate_collector_mode",
        "conn_collector_mode",
        "version",
        "capabilities"
      ]
    },
    "overviewSample": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sample_ms": {
          "type": "integer",
          "minimum": 0
        },
        "tx_bps": {
          "type": "integer",
          "minimum": 0
        },
        "rx_bps": {
          "type": "integer",
          "minimum": 0
        },
        "client_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_clients": {
          "type": "integer",
          "minimum": 0
        },
        "tcp_conns": {
          "type": "integer",
          "minimum": 0
        },
        "udp_conns": {
          "type": "integer",
          "minimum": 0
        },
        "udp_dns_conns": {
          "type": "integer",
          "minimum": 0
        },
        "udp_other_conns": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "sample_ms",
        "tx_bps",
        "rx_bps",
        "client_count",
        "active_clients"
      ]
    },
    "overview": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "samples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/overviewSample"
          }
        },
        "max_samples": {
          "type": "integer",
          "minimum": 0
        },
        "overview_window_samples": {
          "type": "integer",
          "minimum": 2
        },
        "active_client_window_ms": {
          "type": "integer",
          "minimum": 1000
        },
        "active_client_min_bps": {
          "type": "integer",
          "minimum": 1
        },
        "sample_source": {
          "type": "string",
          "minLength": 1
        },
        "conn_semantics": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "samples"
      ]
    },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mac": {
          "type": "string",
          "pattern": "^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$"
        },
        "ips": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "identity_key": {
          "type": "string",
          "description": "Stable client identity key derived from normalized MAC plus VLAN/zone, never from an IP address."
        },
        "zone": {
          "type": "string",
          "minLength": 1
        },
        "interface": {
          "type": "string",
          "minLength": 1
        },
        "hostname": {
          "type": [
            "string",
            "null"
          ],
          "description": "Best known hostname from DHCP or wireless identity sources; null when a static client has no hostname evidence."
        },
        "rx_bps": {
          "type": "integer",
          "minimum": 0
        },
        "tx_bps": {
          "type": "integer",
          "minimum": 0
        },
        "last_seen": {
          "type": "integer",
          "minimum": 0
        },
        "sample_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Monotonic timestamp (ms) of the byte counter sample that produced rx_bytes/tx_bytes and the accompanying rx_bps/tx_bps. Consumers can align client samples with interface samples by this clock."
        },
        "rx_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Cumulative rx bytes observed for this client at sample_ms. Counter may reset when a MAC disappears from the BPF LRU map or when conntrack flows rotate; consumers must tolerate decreases."
        },
        "tx_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Cumulative tx bytes observed for this client at sample_ms."
        },
        "collector_mode": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        },
        "tcp_conns": {
          "type": "integer",
          "minimum": 0
        },
        "udp_conns": {
          "type": "integer",
          "minimum": 0
        },
        "udp_dns_conns": {
          "type": "integer",
          "minimum": 0
        },
        "udp_other_conns": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "mac",
        "identity_key",
        "zone",
        "interface",
        "ips",
        "hostname",
        "rx_bps",
        "tx_bps",
        "last_seen",
        "collector_mode",
        "confidence",
        "warnings"
      ]
    },
    "clientConnectionDetail": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "client_ip": {
          "type": "string",
          "minLength": 1
        },
        "client_port": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "remote_ip": {
          "type": "string",
          "minLength": 1
        },
        "remote_port": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "protocol": {
          "type": "string",
          "enum": [
            "tcp",
            "udp"
          ]
        },
        "state": {
          "type": "string",
          "enum": [
            "established",
            "assured"
          ]
        },
        "direction": {
          "type": "string",
          "enum": [
            "outbound",
            "inbound"
          ]
        },
        "tx_bps": {
          "type": "integer",
          "minimum": 0
        },
        "rx_bps": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "client_ip",
        "client_port",
        "remote_ip",
        "remote_port",
        "protocol",
        "state",
        "direction",
        "tx_bps",
        "rx_bps"
      ]
    },
    "clientConnectionSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "identity_key": {
          "type": "string",
          "minLength": 1
        },
        "hostname": {
          "type": [
            "string",
            "null"
          ]
        },
        "mac": {
          "type": "string",
          "pattern": "^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$"
        },
        "ips": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "interface": {
          "type": "string",
          "minLength": 1
        },
        "zone": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "identity_key",
        "hostname",
        "mac",
        "ips",
        "interface",
        "zone"
      ]
    },
    "client_connections": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "available": {
          "type": "boolean"
        },
        "sample_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "client": {
          "anyOf": [
            {
              "$ref": "#/$defs/clientConnectionSummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "total_connections": {
          "type": "integer",
          "minimum": 0
        },
        "returned_connections": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2048
        },
        "truncated": {
          "type": "boolean"
        },
        "limit": {
          "type": "integer",
          "minimum": 2048,
          "maximum": 2048
        },
        "conn_source": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "conntrack_netlink",
            "conntrack_procfs",
            null
          ]
        },
        "conn_semantics": {
          "type": "string",
          "minLength": 1
        },
        "connections": {
          "type": "array",
          "maxItems": 2048,
          "items": {
            "$ref": "#/$defs/clientConnectionDetail"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        }
      },
      "required": [
        "available",
        "sample_ms",
        "client",
        "total_connections",
        "returned_connections",
        "truncated",
        "limit",
        "conn_source",
        "conn_semantics",
        "connections",
        "warnings"
      ]
    },
    "clients": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "clients": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/client"
          }
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "tcp_conns_total": {
          "type": "integer",
          "minimum": 0
        },
        "udp_conns_total": {
          "type": "integer",
          "minimum": 0
        },
        "udp_dns_conns_total": {
          "type": "integer",
          "minimum": 0
        },
        "udp_other_conns_total": {
          "type": "integer",
          "minimum": 0
        },
        "conntrack_entries_seen": {
          "type": "integer",
          "minimum": 0
        },
        "conntrack_entries_matched": {
          "type": "integer",
          "minimum": 0
        },
        "conntrack_parse_errors": {
          "type": "integer",
          "minimum": 0
        },
        "conn_source": {
          "type": "string",
          "enum": ["conntrack", "conntrack_netlink", "conntrack_procfs", "nss_ecm_direct"]
        },
        "nss_ecm_direct_flows_seen": {
          "type": "integer",
          "minimum": 0
        },
        "nss_ecm_direct_flows_matched": {
          "type": "integer",
          "minimum": 0
        },
        "nss_ecm_direct_parse_errors": {
          "type": "integer",
          "minimum": 0
        },
        "conn_collector_mode": {
          "$ref": "#/$defs/connCollectorMode"
        },
        "conn_semantics": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "clients"
      ]
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "Full",
            "Degraded",
            "Unsupported"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "capabilities": {
          "$ref": "#/$defs/capabilities"
        },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "id",
              "severity",
              "message"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "enum": [
                  "info",
                  "warning",
                  "critical"
                ]
              },
              "message": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        },
        "evidence": {
          "$ref": "#/$defs/healthEvidence"
        }
      },
      "required": [
        "mode",
        "confidence",
        "capabilities",
        "conflicts",
        "warnings",
        "evidence"
      ]
    },
    "reload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "Full",
            "Degraded",
            "Unsupported"
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "ok",
        "mode",
        "warnings",
        "evidence",
        "version"
      ]
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "lan",
            "observe",
            "wan",
            "excluded",
            "unknown"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "active",
            "available",
            "missing",
            "excluded",
            "unsupported"
          ]
        },
        "rx_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "tx_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "rx_bps": {
          "type": "integer",
          "minimum": 0
        },
        "tx_bps": {
          "type": "integer",
          "minimum": 0
        },
        "delta_ms": {
          "type": "integer",
          "minimum": 0
        },
        "sample_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Monotonic timestamp (ms) of the rx_bytes/tx_bytes interface sample. Coverage uses this common daemon sampling window together with integrated client rates."
        },
        "source": {
          "type": "string"
        },
        "coverage": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        }
      },
      "required": [
        "name",
        "role",
        "status"
      ]
